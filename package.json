{
  "name": "@mindstudio-ai/local-model-tunnel",
  "version": "0.5.58",
  "description": "Run local AI models with MindStudio",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mindstudio-local": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup && node dist/cli.js",
    "start": "node dist/cli.js",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "local-update": "npm run build && npm link",
    "clean:destructive": "bash scripts/clean-destructive.sh"
  },
  "keywords": [
    "mindstudio",
    "ollama",
    "local-models",
    "ai"
  ],
  "author": "MindStudio",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mindstudio-ai/mindstudio-local-model-tunnel"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "conf": "^15.1.0",
    "esbuild": "^0.28.0",
    "ink": "^7.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "ollama": "^0.6.3",
    "open": "^11.0.0",
    "puppeteer-core": "^24.42.0",
    "react": "^19.2.5",
    "typescript": "^6.0.2",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/ws": "^8.18.1",
    "prettier": "^3.8.2",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
